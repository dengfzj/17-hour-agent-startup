# Local Growth OS runtime
NODE_ENV=development
PORT=8787
APP_ORIGIN=http://localhost:5173,http://127.0.0.1:5174
SERVE_STATIC_FRONTEND=true
LOCAL_GROWTH_API_KEY=
WORKSPACE_DATA_PATH=data/workspace.json
WORKSPACE_ID=local-growth-os
PUBLIC_API_BASE_URL=
# Launch readiness requires PUBLIC_API_BASE_URL to be a public HTTPS origin before live checkout.

# Local development can use header-derived identity only when explicitly enabled.
# Never enable this in production.
LOCAL_GROWTH_ALLOW_HEADER_AUTH=

# Production JWT auth. NODE_ENV=production requires JWT_PUBLIC_KEY, JWT_ISSUER, and JWT_AUDIENCE.
# Operator JWTs must include organization_id or org_id matching workspace business.id.
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_ISSUER=
JWT_AUDIENCE=

# Production database
DATABASE_URL=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BIDFLOW_STARTER=
STRIPE_PRICE_BIDFLOW_GROWTH=
STRIPE_PRICE_BIDFLOW_PRO=
STRIPE_PRICE_REPUTELOOP_STARTER=
STRIPE_PRICE_REPUTELOOP_GROWTH=
STRIPE_PRICE_REPUTELOOP_PRO=

# Email provider: choose one
POSTMARK_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_MESSAGE_STREAM=outbound
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
EMAIL_WEBHOOK_SECRET=
# Email unsubscribe webhooks require x-local-growth-webhook-secret or Authorization: Bearer when EMAIL_WEBHOOK_SECRET is set or NODE_ENV=production.

# SMS provider
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
# Inbound Twilio webhooks require X-Twilio-Signature when TWILIO_AUTH_TOKEN is set or NODE_ENV=production.
# Configure Twilio inbound webhook to: ${PUBLIC_API_BASE_URL}/api/webhooks/twilio/inbound

# Configure provider unsubscribe webhook to: ${PUBLIC_API_BASE_URL}/api/webhooks/email/unsubscribe
# Configure Stripe webhook to: ${PUBLIC_API_BASE_URL}/api/billing/webhook

# Public token link abuse guard for onboarding, checkout handoff, and recovery links.
PUBLIC_TOKEN_RATE_WINDOW_MS=60000
PUBLIC_TOKEN_RATE_MAX=20
# Production public checkout requires a scoped /buy?handoff token unless this is explicitly set to true.
ENABLE_PUBLIC_SELF_SERVE_CHECKOUT=false

# Google Business Profile OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ACCESS_TOKEN=
GOOGLE_ACCOUNT_ID=
GOOGLE_LOCATION_ID=

# Frontend
# Leave empty for same-origin production serving through npm run start.
# For split local dev only, set VITE_API_BASE_URL=http://localhost:8787 in .env.local.
VITE_API_BASE_URL=
